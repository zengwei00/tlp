===================================================================
--- tlp-1.7.0.1.orig/func.d/10-tlp-func-cpu
+++ tlp-1.7.0.1/func.d/10-tlp-func-cpu
@@ -123,6 +123,51 @@ set_cpu_scaling_governor () {
     return 0
 }
 
+set_ondemand_global_sampling_down_factor () {
+    # set ondemand governor sampling down factor -- $1: 0=ac mode, 1=battery mode
+    local cfg factor ec cpu
+
+    if [ "$1" = "1" ]; then
+        factor=${ONDEMAND_GLOBAL_SAMPLING_DOWN_FACTOR_ON_BAT:-}
+        cfg="ONDEMAND_GLOBAL_SAMPLING_DOWN_FACTOR_ON_BAT"
+    else
+        factor=${ONDEMAND_GLOBAL_SAMPLING_DOWN_FACTOR_ON_AC:-}
+        cfg="ONDEMAND_GLOBAL_SAMPLING_DOWN_FACTOR_ON_AC"
+    fi
+
+    if [ -z "$factor" ]; then
+        echo_debug "pm" "set_ondemand_global_sampling_down_factor($1).not_configured"
+        return 0
+    fi
+
+    # check if ondemand governor is available
+    if ! grep -q ondemand "${CPUD}/cpu0/cpufreq/scaling_governor" 2>/dev/null; then
+        echo_debug "pm" "set_ondemand_global_sampling_down_factor($1).ondemand_not_available"
+        return 0
+    fi
+
+    # apply global sampling down factor
+    ec=0
+
+    if [ -f "${CPUD}/cpufreq/ondemand/global_sampling_down_factor" ]; then
+        if ! write_sysf "$factor" "${CPUD}/cpufreq/ondemand/global_sampling_down_factor"; then
+            echo_debug "pm" "set_ondemand_global_sampling_down_factor($1).write_error: ${CPUD}/cpufreq/ondemand/global_sampling_down_factor $factor; rc=$?"
+            ec=$((ec+1))
+        fi
+    fi
+
+
+    if [ "$ec" -gt 0 ]; then
+        echo_debug "pm" "set_ondemand_global_sampling_down_factor($1).failed: $factor; ec=$ec"
+        echo_message "Error in configuration at ${cfg}=\"${factor}\": failed to set global_sampling_down_factor."
+        return 1
+    else
+        echo_debug "pm" "set_ondemand_global_sampling_down_factor($1): $factor; ec=$ec"
+    fi
+
+    return 0
+}
