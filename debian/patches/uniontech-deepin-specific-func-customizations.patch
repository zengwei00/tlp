Index: tlp-1.7.0.1/func.d/45-tlp-func-gpu
===================================================================
--- tlp-1.7.0.1.orig/func.d/45-tlp-func-gpu
+++ tlp-1.7.0.1/func.d/45-tlp-func-gpu
@@ -257,3 +257,54 @@ set_abm_level () {
 
     return 0
 }
+
+set_devfreq_governor () {
+    # set devfreq governor -- $1: 0=ac mode, 1=battery mode
+    local governor_param devfreq_path governor_val ec=0
+
+    # Determine which parameter to use based on power source
+    if [ "$1" = "1" ]; then
+        governor_param=${DEVFREQ_GOVERNOR_ON_BAT:-}
+    else
+        governor_param=${DEVFREQ_GOVERNOR_ON_AC:-}
+    fi
+
+    # If no parameter configured, return early
+    if [ -z "$governor_param" ]; then
+        echo_debug "pm" "set_devfreq_governor($1).not_configured"
+        return 0
+    fi
+
+    # Iterate through all devfreq devices with pattern devfreq*
+    for devfreq_path in /sys/class/devfreq/devfreq*/; do
+        # Check if the directory exists and is actually a directory
+        if [ -d "$devfreq_path" ]; then
+            # Check if governor file exists for this device
+            if [ -f "${devfreq_path}governor" ]; then
+                # Check if the requested governor is available for this device
+                if [ -f "${devfreq_path}available_governors" ] &&
+                   grep -qw "$governor_param" "${devfreq_path}available_governors" 2>/dev/null; then
+                    # Apply the governor setting
+                    if ! write_sysf "$governor_param" "${devfreq_path}governor"; then
+                        echo_debug "pm" "set_devfreq_governor($1).write_error: ${devfreq_path}governor $governor_param; rc=$?"
+                        ec=$((ec+1))
+                    else
+                        echo_debug "pm" "set_devfreq_governor($1): applied $governor_param to ${devfreq_path}governor"
+                    fi
+                else
+                    echo_debug "pm" "set_devfreq_governor($1).governor_not_available: $governor_param for ${devfreq_path}"
+                fi
+            else
+                echo_debug "pm" "set_devfreq_governor($1).no_governor_file: ${devfreq_path}governor"
+            fi
+        fi
+    done
+
+    if [ "$ec" -gt 0 ]; then
+        echo_debug "pm" "set_devfreq_governor($1).failed: $governor_param; ec=$ec"
+        echo_message "Error in devfreq governor configuration: failed to set governor(s)."
+        return 1
+    fi
+
+    return 0
+}
